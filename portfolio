<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dua | WordPress & Frontend Developer</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
scroll-behavior:smooth;
font-family:'Poppins',sans-serif;
}

body{
background:#f5f7fb;
color:#333;
}

header{
background:#0f172a;
position:fixed;
width:100%;
top:0;
z-index:1000;
}

nav{
max-width:1200px;
margin:auto;
display:flex;
justify-content:space-between;
align-items:center;
padding:18px 30px;
}

.logo{
color:#fff;
font-size:28px;
font-weight:700;
}

nav ul{
display:flex;
list-style:none;
gap:25px;
}

nav ul li a{
color:#fff;
text-decoration:none;
font-weight:500;
transition:.3s;
}

nav ul li a:hover{
color:#38bdf8;
}

section{
padding:110px 10% 80px;
min-height:100vh;
}

.hero{
display:flex;
justify-content:space-between;
align-items:center;
flex-wrap:wrap;
gap:40px;
}

.hero-text{
flex:1;
}

.hero-text h3{
color:#0ea5e9;
font-size:22px;
}

.hero-text h1{
font-size:55px;
margin:10px 0;
}

.hero-text h2{
font-size:28px;
color:#555;
margin-bottom:20px;
}

.hero-text p{
line-height:1.8;
margin-bottom:30px;
}

.btn{
display:inline-block;
padding:14px 30px;
background:#0ea5e9;
color:white;
text-decoration:none;
border-radius:8px;
transition:.3s;
}

.btn:hover{
background:#0284c7;
}

.hero-image{
flex:1;
display:flex;
justify-content:center;
}

.hero-image img{
width:320px;
border-radius:50%;
border:8px solid white;
box-shadow:0 15px 35px rgba(0,0,0,.15);
}

.title{
text-align:center;
font-size:40px;
margin-bottom:50px;
color:#0f172a;
}

.about-content{
max-width:900px;
margin:auto;
text-align:center;
line-height:1.9;
font-size:18px;
}

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:25px;
}

.card{
background:#fff;
padding:30px;
border-radius:15px;
box-shadow:0 10px 25px rgba(0,0,0,.08);
transition:.3s;
}

.card:hover{
transform:translateY(-10px);
}

.card h3{
margin-bottom:15px;
color:#0ea5e9;
}

.skills{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:25px;
}

.skill{
background:#fff;
padding:25px;
border-radius:12px;
box-shadow:0 10px 20px rgba(0,0,0,.08);
}

.skill h4{
margin-bottom:15px;
}

.bar{
background:#ddd;
height:10px;
border-radius:20px;
overflow:hidden;
}

.fill{
height:100%;
background:#0ea5e9;
}

.contact{
max-width:700px;
margin:auto;
background:white;
padding:40px;
border-radius:15px;
box-shadow:0 10px 25px rgba(0,0,0,.08);
}

.contact form{
display:flex;
flex-direction:column;
gap:20px;
}

input,textarea{
padding:15px;
border:1px solid #ccc;
border-radius:8px;
font-size:16px;
}

textarea{
resize:none;
height:140px;
}

button{
padding:15px;
border:none;
background:#0ea5e9;
color:white;
font-size:17px;
border-radius:8px;
cursor:pointer;
}

button:hover{
background:#0284c7;
}

footer{
background:#0f172a;
color:white;
text-align:center;
padding:20px;
}

@media(max-width:768px){

.hero{
text-align:center;
flex-direction:column-reverse;
}

.hero-text h1{
font-size:42px;
}

nav{
flex-direction:column;
gap:15px;
}

nav ul{
flex-wrap:wrap;
justify-content:center;
}

}

</style>

</head>
<body>

<header>

<nav>

<div class="logo">Dua</div>

<ul>
<li><a href="#home">Home</a></li>
<li><a href="#about">About</a></li>
